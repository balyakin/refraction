{
  "rules": [
    {
      "id": "INST001",
      "category": "install-hook",
      "severity": "critical",
      "confidence": "high",
      "title": "Suspicious package install or build hook",
      "description": "Manifest or build text contains install-time behavior that can download, execute, or hide code.",
      "rationale": "Package lifecycle hooks execute before users inspect installed artifacts and are a common supply-chain attack surface.",
      "remediation": "Remove install-time execution, pin trusted build inputs, or document and suppress a necessary hook.",
      "attack_narrative": "An npm postinstall hook or Python .pth file downloads and launches code during dependency installation.",
      "match_type": "regex",
      "patterns": [
        "(?i)\"(preinstall|install|postinstall|prepare|prepublish|prepublishOnly)\"\\s*:\\s*\"[^\"]*(curl|wget|powershell|python\\s+-c|node\\s+-e|bash\\s+-c)",
        "(?i)(curl|wget)\\s+[^\\n]+\\|\\s*(sh|bash|python|node|powershell)",
        "(?i)python\\s+-c\\s+['\"][^'\"]*(urllib|requests|socket|base64|exec)",
        "(?i)^\\s*import\\s+(os|subprocess|socket|urllib|base64)\\b.*#?\\s*\\.pth",
        "(?i)setup\\.py[^\\n]*(cmdclass|setup_requires|dependency_links)",
        "(?i)pyproject\\.toml[^\\n]*(build-backend|backend-path)",
        "(?i)build\\s*=\\s*\"build\\.rs\"",
        "(?i)build\\.rs[^\\n]*(Command::new|curl|wget|powershell)",
        "(?i)Gem::Installer|extensions\\s*=|post_install_message",
        "(?i)Rake::Task|Gem\\.post_install",
        "(?i)<exec\\b|<target\\b[^>]*BeforeTargets\\s*=|<Import\\b[^>]*Project\\s*=",
        "(?i)<plugin>[\\s\\S]{0,120}exec-maven-plugin",
        "(?i)tasks\\.register\\([^\\n]*(Exec|JavaExec)",
        "(?i)Exec\\s*\\{[^\\n]*(curl|wget|bash|powershell)",
        "(?i)RUN\\s+(curl|wget)\\s+[^\\n]+\\|\\s*(sh|bash)",
        "(?i)ADD\\s+https?://",
        "(?i)on:\\s*pull_request_target",
        "(?i)actions/checkout@[^\\n]+persist-credentials:\\s*true",
        "(?i)git\\s+config\\s+filter\\.[^.]+\\.(clean|smudge)",
        "(?i)submodule\\..*\\.update\\s*=\\s*!",
        "(?i)^\\s*(post_install|pre_install|post_upgrade)\\s*\\(\\)\\s*\\{",
        "(?i)source=\\([^\\)]*https?://",
        "(?i)Makefile[^\\n]*(curl|wget|bash\\s+-c|powershell)",
        "(?i)Jenkinsfile[^\\n]*(sh\\s+['\"].*(curl|wget)|bat\\s+['\"].*powershell)",
        "(?i)docker-compose\\.(ya?ml)[^\\n]*(privileged:\\s*true|/var/run/docker\\.sock)",
        "(?i)terraform[^\\n]*(local-exec|remote-exec)"
      ],
      "case_insensitive": false,
      "regions": ["manifest", "string", "raw-text"],
      "min_entropy": 4.0,
      "references": ["https://docs.npmjs.com/cli/using-npm/scripts", "https://packaging.python.org/en/latest/specifications/"],
      "cwe": ["CWE-829", "CWE-94"],
      "mitre_attack": ["T1195", "T1059"],
      "ecosystems": ["npm", "python", "rust", "ruby", "docker", "make", "gradle", "maven", "nuget", "github-actions", "git"],
      "attack_examples": ["A postinstall script fetches a shell script over HTTP and pipes it to a shell."],
      "false_positive_examples": ["A documented, pinned, audited build step in a private internal repository."],
      "status": "active",
      "replaced_by": ""
    }
  ]
}
